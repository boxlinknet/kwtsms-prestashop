# Apache 2.4
<IfModule mod_authz_core.c>
    <Files *.php>
        Require all denied
    </Files>
    <Files index.php>
        Require all granted
    </Files>
</IfModule>

# Apache 2.2
<IfModule !mod_authz_core.c>
    <Files *.php>
        Order allow,deny
        Deny from all
    </Files>
    <Files index.php>
        Order allow,deny
        Allow from all
    </Files>
</IfModule>
